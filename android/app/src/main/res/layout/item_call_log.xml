<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:tag="bg"
        android:background="#0D0F14"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <!-- 左侧：号码 + 卡标签 + 时间 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- 号码 + 卡标签 横排 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/itemCallNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="138****8888"
                    android:tag="text"
                    android:textColor="#E8DCC8"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <!-- 卡标签 -->
                <TextView
                    android:id="@+id/itemSimSlot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="#1A4F8EF7"
                    android:paddingStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="2dp"
                    android:text="卡1"
                    android:textColor="#4F8EF7"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 时间 -->
            <TextView
                android:id="@+id/itemCallTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="04-25 17:30"
                android:tag="text2"
                android:textColor="#605040"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 右侧：通话状态 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical|end"
            android:orientation="vertical">

            <!-- 通话类型图标 -->
            <TextView
                android:id="@+id/itemCallType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="📞"
                android:textSize="16sp" />

            <!-- 通话状态文字 -->
            <TextView
                android:id="@+id/itemCallStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="end"
                android:text="接通 12s"
                android:tag="text2"
                android:textColor="#605040"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:tag="divider"
        android:background="#14FFFFFF"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

</LinearLayout>
